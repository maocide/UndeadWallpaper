<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Per-wallpaper settings dialog. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textStyle="bold" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/item_enabled_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/enabled_label" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/loop_count_label">

            <!-- Loop count belongs to the playlist item now. -->
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/item_loop_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/loop_count_hint"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/scaling_mode"
            android:textAppearance="?attr/textAppearanceBody1" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/item_scaling_mode_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/item_scaling_mode_fit"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scaling_mode_fit" />

            <com.google.android.material.chip.Chip
                android:id="@+id/item_scaling_mode_fill"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scaling_mode_fill" />

            <com.google.android.material.chip.Chip
                android:id="@+id/item_scaling_mode_stretch"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scaling_mode_stretch" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/horizontal_position" />

        <com.google.android.material.slider.Slider
            android:id="@+id/item_position_x_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="-1"
            android:valueTo="1"
            android:stepSize="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vertical_position" />

        <com.google.android.material.slider.Slider
            android:id="@+id/item_position_y_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="-1"
            android:valueTo="1"
            android:stepSize="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/zoom" />

        <com.google.android.material.slider.Slider
            android:id="@+id/item_zoom_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0.5"
            android:valueTo="3"
            android:stepSize="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rotation" />

        <com.google.android.material.slider.Slider
            android:id="@+id/item_rotation_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="-180"
            android:valueTo="180"
            android:stepSize="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/brightness" />

        <com.google.android.material.slider.Slider
            android:id="@+id/item_brightness_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="2"
            android:stepSize="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/speed" />

        <com.google.android.material.slider.Slider
            android:id="@+id/item_speed_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0.25"
            android:valueTo="3"
            android:stepSize="0.05" />

    </LinearLayout>
</ScrollView>
