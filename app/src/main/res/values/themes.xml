<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.UndeadWallpaper" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/light_green</item>
        <item name="colorSecondary">@color/zombie_green</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.UndeadWallpaper.BottomSheetDialog</item>

    </style>

    <style name="Theme.UndeadWallpaper" parent="Base.Theme.UndeadWallpaper" />

    <style name="CornerStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ThemeOverlay.UndeadWallpaper.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.UndeadWallpaper.BottomSheet</item>
    </style>

    <style name="Widget.UndeadWallpaper.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">?attr/colorSurface</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.UndeadWallpaper.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.UndeadWallpaper.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>
</resources>